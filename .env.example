# --- signer (required to record attestations; omit for verdict-only mode) ---
# Base58 64-byte secret key OR a Solana keypair-file JSON array. The key must
# be the cluster's global moderation_authority OR a registered, non-revoked
# roster ModerationAttestor (the service auto-detects which and attaches the
# roster PDA). NEVER commit this. Prefer your platform's secret store.
MODERATION_SIGNER_SECRET=

# --- chain ---
RPC_URL=https://api.mainnet-beta.solana.com
CLUSTER_LABEL=mainnet

# --- attestation expiry (seconds; 0 disables — on-chain expires_at=0) ---
ATTESTATION_TTL_SECONDS=2592000

# --- abuse bounds (each CLEAN attest signs + pays a mainnet tx) ---
RATE_LIMIT_PER_IP=6
RATE_LIMIT_GLOBAL=60
RATE_LIMIT_WINDOW_MS=60000

# Optional shared cross-instance limiter (Upstash Redis REST). Falls back to a
# bounded per-instance window when unset.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional bearer API keys (comma-separated). When set, POST endpoints require
# Authorization: Bearer <key>. Leave empty for an open, rate-limited service.
ATTEST_API_KEYS=

# Self-host port
PORT=8787
